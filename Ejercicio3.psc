Algoritmo Ejercicio3
	Definir letra Como Caracter
	Escribir Sin Saltar "Digite una letra:"
	Leer letra

	Segun letra Hacer
		"A" o "a":
			Escribir "EXCELENTE"
		"B" o "b":
			Escribir "BUENO"
		"C" o "c":
			Escribir "REGULAR"
		"D" o "d":
			Escribir "DEFICIENTE"
		"F" o "f":
			Escribir "REPOBRADO"
		De Otro Modo:
			Escribir "Letra no valida!!!"
	Fin Segun
FinAlgoritmo
